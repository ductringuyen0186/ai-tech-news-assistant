# Keep the image small — drop dev artifacts the runtime doesn't need.

# Python local artifacts
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments — the image creates its own /opt/venv
venv/
.venv/

# Local SQLite DB (production uses /data/news.db on Fly volume)
news.db
news.db-journal
news_assistant.db
data/

# Sentence-transformers cache (pre-downloaded at build time into /opt/models)
models/

# IDE / OS
.vscode/
.idea/
.DS_Store
*.swp

# Test artifacts
htmlcov/
.coverage
.tox/

# Misc
*.log
*.tmp
.env
.env.local
